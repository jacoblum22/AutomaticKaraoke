# STUB_VIDEO_URL=https://automatic-karaoke.vercel.app/sample.mp4  (see orchestrator.py)

# Phase 3 — local Demucs (not used by lean web image):
# pip install -r backend/requirements-demucs.txt

# Phase 4 — local Whisper (not used by lean web image):
# pip install -r backend/requirements-whisper.txt

# Phase 6 — Modal secret ``karaoke-r2`` (preferred over .env in production)
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev   # or custom CDN domain

# Phase 7 Step 7 — Modal secret ``karaoke-api-key`` (optional; leave API_KEY empty to disable)
# API_KEY=

# Phase 7 Step 6 — presigned browser upload CORS: docs/r2-cors.example.json on the R2 bucket
