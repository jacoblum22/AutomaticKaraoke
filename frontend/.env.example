# Phase 1: in-browser mock (no network to API)
VITE_USE_MOCK=true

# Phase 2 local against Modal: copy .env.modal → .env.local, or run npm run smoke:modal

# Phase 2+: Modal base URL; used only when VITE_USE_MOCK=false (no trailing slash)
# Deployed (jacoblum22): https://jacoblum22--karaoke-api.modal.run
# Dev (modal serve):     https://jacoblum22--karaoke-api-dev.modal.run
VITE_API_URL=https://jacoblum22--karaoke-api.modal.run

# Required for Modal when api_key_required (copy .env.modal → .env.local)
VITE_API_KEY=test-karaoke-phase7-key
